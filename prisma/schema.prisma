generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  walletAddress  String    @unique
  encryptedKey   String
  walletFundedAt DateTime?
  createdAt      DateTime  @default(now())
}
